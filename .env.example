# ========================================
# VARIÁVEIS DE AMBIENTE — STILUS PLANEJADOS
# ========================================
# Copie este arquivo para .env e preencha os valores

# --- Banco de dados (Railway PostgreSQL) ---
DATABASE_URL=postgresql://usuario:senha@host.railway.app:5432/railway

# --- Sessão (crie uma string longa e aleatória) ---
SESSION_SECRET=troque_por_uma_chave_secreta_longa_aqui_123456

# --- Admin painel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque_sua_senha_aqui

# --- Porta ---
PORT=3000
